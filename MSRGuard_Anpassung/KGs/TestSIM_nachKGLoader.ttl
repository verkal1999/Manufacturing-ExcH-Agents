    dp:hasPOUDeclarationHeader """FUNCTION_BLOCK VSG_OperatingModes
VAR_INPUT
	Start 			: BOOL;
	Stop			: BOOL;
	Reset			: BOOL;
	Schalter		: BOOL;
	Schrittkette_GS	: BOOL;
	Count1 : INT := 0;
	Count2 : INT := 0;
	Alt_abort: BOOL;
	Err_detected: BOOL;
	Diag_finished: BOOL;
	Alt_found: BOOL;
	Cycle_finished: BOOL;

END_VAR
VAR_OUTPUT
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	A1 : BOOL := FALSE; //Initialzustand
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	A2 : BOOL; //Stillstand angefordert am Ende des Zyklus
//	A3 : BOOL; //Stillstand angefordert in einem bestimmten Zustand
//	A4 : BOOL; //Erhaltener Stillstand
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	A5 : BOOL; //Vorbereitung zur Wiederaufnahme nach Störung
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	A6 : BOOL; //Fahrt in den Initialzustand
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	F1 : BOOL; //Normalbetrieb
//	F2 : BOOL; //Anfahren
//	F3 : BOOL; //Abfahren
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	F4 : BOOL; //Handbetrieb
//	F5 : BOOL; //Schrittbetrieb
//	F6 : BOOL; //Testbetrieb
{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	D1 : BOOL; //Not-Aus
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	D2 : BOOL; //Diagnose und Störbehandlung
	{attribute 'OPC.UA.DA' := '1'} // für OPC UA freigeben
	D3 : BOOL; //Produktion trotz Störung
	MethodCall_InitStateDrive : BOOL;
	InputVar_InitStateDrive : BOOL;
END_VAR
VAR
	bFirstScan : BOOL := TRUE;
	FirstScanCount: INT := 0;
	AlwaysTrue : BOOL := TRUE;
	TestingVariable : BOOL;	
	 nTaskIdx : DINT;
	RS_InitialState: RS;
	RS_InitialState11: RS;	
