    dp:hasPOUCode """// POU VSG_InitialStateDrive body
VSG_InitDrive_Rotate_CW(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := NOT ESS,
    Direction := DirectionRotation,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor01_Rotation,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);

VSG_Init_RotateCW := VSG_InitDrive_Rotate_CW.DigitalOutputControl_01;
VSG_Init_RotateCCW := FALSE;
ResetMethodCall_RotateCW := VSG_InitDrive_Rotate_CW.ResetMethodCall;


VSG_InitDrive_Vertical_Up(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := NOT ESS,
    Direction := DirectionVertical,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor02_Vertical,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);

VSG_Init_VerticalUp := VSG_InitDrive_Vertical_Up.DigitalOutputControl_01;
VSG_Init_VerticalDown := FALSE;
ResetMethodCall_RGB_Vertical := VSG_InitDrive_Vertical_Up.ResetMethodCall;


VSG_InitDrive_Horizontal_Backwards(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := NOT ESS,
    Direction := DirectionHorizontal,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor03_horizontal,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);

VSG_Init_HorizontalForwards := FALSE;
VSG_Init_HorizontalBackwards := VSG_InitDrive_Horizontal_Backwards.DigitalOutputControl_01;
ResetMethodCall_RGB_Horizontal := VSG_InitDrive_Horizontal_Backwards.ResetMethodCall;""" ;
