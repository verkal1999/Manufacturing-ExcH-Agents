ConveyorBeltForward := ((((((F1) OR (A2))) AND (CB_Forwards))) OR (((Start) AND (F4))));
ConveyorBeltBackward := ((((((F1) OR (A2))) AND (CB_Backwards))) OR (((Start) AND (F4))));
RGB_Forwards := ((((((F1) OR (A2))) AND (((RGB_Forwards01) OR (RGB_Forwards02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_Forwards))));
RGB_Backwards := ((((((F1) OR (A2))) AND (((RGB_Backwards01) OR (RGB_Backwards02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_Backwards))));
RGB_VerticalDown := ((((((F1) OR (A2))) AND (((RGB_VertikalDown01) OR (RGB_VertikalDown02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_VertikalDown))));
RGB_VerticalUp := ((((((F1) OR (A2))) AND (((RGB_VertikalUp01) OR (RGB_VertikalUp02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_VertikalUp))));
RGB_HorizontalForward := ((((((F1) OR (A2))) AND (((RGB_HorizontalForwards01) OR (RGB_HorizontalForwards02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_HorizontalForwads))));
RGB_HorizontalBackward := ((((((F1) OR (A2))) AND (((RGB_HorizontalBackwards01) OR (RGB_HorizontalBackwards02))))) OR (((Start) AND (F4))) OR (((A6) AND (Init_RGB_HorizontalBackwards))));
Light_Q1 := F1;
Light_Q2 := F4;
Light_Q3 := A1;""" ;
