ag:FBType_HRL_OperatingModes a ag:class_CustomFBType,
        ag:class_FBType ;
    dp:hasPOUCode """import time

def HRL_OperatingModes(Stop: bool, D2: bool, A5: bool, D3: bool, Alt_abort: bool, F1: int, Err_detected: int, Alt_found: bool, A2, D1, Diag_finished, Reset, A6, F4, Schalter, V_50000000005, A1, Schrittkette_GS, FirstScanCount, V_60000000004, Start, Cycle_finished):
    \"\"\"Auto-generated from PLCopen XML (vereinfachte Semantik).\"\"\"

    def OR_1(V_10000000002, V_10000000003):
        result = D2 or A5
        return result
    V_10000000004 = OR_1(D2, A5)

    def SR(V_10000000001, V_10000000004):
        result = V_10000000004
        return result
    V_10000000005 = SR(Stop, V_10000000004)

    def AND_1(V_20000000000, V_20000000001):
        result = D3 and Alt_abort
        return result
    V_20000000002 = AND_1(D3, Alt_abort)

    def AND_2(V_20000000003, V_20000000004):
        result = F1 and Err_detected
        return result
    V_20000000005 = AND_2(F1, Err_detected)

    def OR_2(V_20000000002, V_20000000005):
        result = V_20000000002 or V_20000000005
        return result
    V_20000000006 = OR_2(V_20000000002, V_20000000005)

    def AND_3(V_20000000007, V_20000000008):
        result = D3 and Alt_abort
        return result
    V_20000000009 = AND_3(D3, Alt_abort)

    def OR_3(V_20000000009, V_20000000010):
        result = V_20000000009 or A5
        return result
