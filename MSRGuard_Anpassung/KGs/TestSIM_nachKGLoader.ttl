ag:FBType_MBS_DmPD_AS_RotationMove a ag:class_CustomFBType,
        ag:class_FBType ;
    dp:hasJobMethodName "JobMethode_RotationMove"^^xsd:string ;
    dp:hasPOUCode """// POU MBS_DmPD_AS_RotationMove body
MBS_DmPD_RotationMove(
    MethodCall := MethodCall_RotationMove,
    EmergencyStopSignal := ESS,
    Direction := DirectionRotation,
    InitStateDrive_Input := ,
    DI01 := TouchSensor_01,
    DI02 := TouchSensor_02,
    TouchSensorRelief := ,
    TOF_Time_MotorControl := ,
    TOF_Time_TouchSensorRelief := ,
    OperatingMode := AutomaticMode
);
DO_MovingRotationPmPD_01 := MBS_DmPD_RotationMove.DigitalOutputControl_01;""" ;
    dp:hasPOUDeclarationHeader """{attribute 'OPC.UA.DA.JobMethod' := 'JobMethode_RotationMove'}
FUNCTION_BLOCK MBS_DmPD_AS_RotationMove
VAR
	AlwaysTrue : BOOL := TRUE;
	// Used for debugging purposes to display InputArguments of method call
	MethodCall_RotationMove : BOOL := FALSE; // used to store InputArg "MethodCall" from Start() method
	ResetMethodCall : BOOL := FALSE;
	DirectionRotation : STRING;
	callCounterStart : ULINT; // counts how many times the Start() method has been called
	callCounterCheckState : ULINT; // counts how many times the CheckState() method has been called
	callCounterAbort : ULINT; // counts how many times the Abort() method has been called
	
	// Variables to determine if a job has been started (Start() method has been called) or finished
	jobRunning : BOOL;
	jobFinished : BOOL;

	// State machine variable
	state : UDINT;
	
	//Variablen des Transport FBs
	MBS_DmPD_RotationMove : AxisControl_MultipleInputSensors;
END_VAR
	
VAR_INPUT
	ESS: BOOL;
	TouchSensor_01 : BOOL;
	TouchSensor_02 : BOOL;
	AutomaticMode: BOOL;
END_VAR

VAR_OUTPUT
	DO_MovingRotationPmPD_01 : BOOL;
	DO_MovingRotationPmPD_02 : BOOL;
END_VAR"""^^xsd:string ;
