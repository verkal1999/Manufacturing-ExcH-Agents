	LightSensor_01 : BOOL;
	TOF_Time_MotorControl : TIME;
	AutomaticMode: BOOL;
END_VAR

VAR_OUTPUT
	DO_MovingHorizontalCB_01 : BOOL;
END_VAR"""^^xsd:string ;
