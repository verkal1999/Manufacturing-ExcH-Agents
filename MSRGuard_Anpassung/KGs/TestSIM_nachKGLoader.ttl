    OperatingMode := InitDriveMode
);
MotorControl_CCW := MBS_DmPD_InitDrive_Rotate_CCW.DigitalOutputControl_01;""" ;
    dp:hasPOUDeclarationHeader """FUNCTION_BLOCK MBS_DmPD_InitialStateDrive
VAR_INPUT
