    dp:hasPOUCode """// POU MBS_DmPD_InitialStateDrive body
MBS_DmPD_InitDrive_Rotate_CW(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := ESS,
    Direction := DirectionCW,
    InitStateDrive_Input := InputInitialStateDrive,
    DI01 := ,
    DI02 := DI02_CW,
    TouchSensorRelief := ,
    TOF_Time_MotorControl := ,
    TOF_Time_TouchSensorRelief := ,
    OperatingMode := InitDriveMode
);
MotorControl_CW := MBS_DmPD_InitDrive_Rotate_CW.DigitalOutputControl_01;
MBS_DmPD_InitDrive_Rotate_CCW(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := ESS,
    Direction := DirectionCCW,
    InitStateDrive_Input := ,
    DI01 := DI01_CCW,
    DI02 := DI02_CCW,
    TouchSensorRelief := ,
