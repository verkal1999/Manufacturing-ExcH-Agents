    dp:hasPOUCode """// POU HRL_RGB_InitialStateDrive body
HRL_RGB_SRM_InitDrive(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := ESS,
    Direction := DirectionVerticalSRM,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor01_SRM,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);
SRM_MotorBackwards := HRL_RGB_SRM_InitDrive.DigitalOutputControl_01;

HRL_RGB_Vertical_InitDrive(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := ESS,
    Direction := DirectionVertical,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor02_RGB_vertical,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);
RGB_VerticalUp := HRL_RGB_Vertical_InitDrive.DigitalOutputControl_01;

HRL_RGB_Horizontal_InitDrive(
    MethodCall := MethodCall_InitDrive,
    EmergencyStopSignal := ESS,
    Direction := DirectionHorizontal,
    InitStateDrive_Input := InputInitDriveMode,
    DI01 := FALSE,
    DI02 := TouchSensor03_RGB_horizontal,
    TouchSensorRelief := TSR,
    TOF_Time_MotorControl := T#0MS,
    TOF_Time_TouchSensorRelief := TOF_Time_TSR,
    OperatingMode := InitDriveMode
);
RGB_HorizontalBackwards := HRL_RGB_Horizontal_InitDrive.DigitalOutputControl_01;""" ;
