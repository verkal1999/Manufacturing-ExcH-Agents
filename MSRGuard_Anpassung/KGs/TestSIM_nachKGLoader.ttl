	NeverTrue: BOOL := FALSE;
	SR_D1: SR;
	RS_D2: RS;
	
	RS_D3: RS;
	RS_A5: RS;
	
	
	bFirstCycle: BOOL;
END_VAR"""^^xsd:string ;
