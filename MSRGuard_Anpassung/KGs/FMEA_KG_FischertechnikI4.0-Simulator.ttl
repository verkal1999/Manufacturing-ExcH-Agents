dp:hadMonActExecutionParams a owl:DatatypeProperty ;
    rdfs:domain cl:ExecutedMonAct ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dp:hasExecutionParams .

dp:hadSRExecutionParams a owl:DatatypeProperty ;
