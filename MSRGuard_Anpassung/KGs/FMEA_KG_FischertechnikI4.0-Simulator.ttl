dp:hasSysReactParams a owl:DatatypeProperty ;
    rdfs:comment """Buchstaben:\r
- g: Gruppe, eine von meta, method, input, output\r
\r
- k: Schlüssel oder Parametername, z. B. speed, status\r
\r
- i: optionale Positionsnummer des Parameters, damit Reihenfolgen stabil sind\r
\r
- id: NodeId der zugehörigen OPC UA Variable oder Methode, wenn zutreffend\r
\r
 - t: Datentyp als String, z. B. bool, int32, double, string, nodeid, json\r
\r
- v: Wert in passendem JSON Typ\r
\r
- step: Ganzzahl 0..N-1 für die Reihenfolge der Methodenaufrufe in der Systemreaktion\r
\r
- seq: strikt monotone Ganzzahl (0,1,2,…) über alle Rows, damit du die exakte Ereignisreihenfolge rekonstruierst\r
\r
- callId: stabile ID (z. B. "0", "1" oder UUID) pro einzelner Methoden-Invocation innerhalb eines Steps (hilfreich, falls Retrys oder Teil-Events geloggt werden sollen)\r
\r
!!!Minimalregeln!!!!\r
\r
- Alle Rows, die zu einem Methodenaufruf gehören, teilen sich denselben step und callId.\r
\r
- seq steigt für jede Row; zum Re-Play einfach nach seq sortieren.\r
\r
- Pro Call mindestens:\r
\r
- eine method-Row mit der methodId\r
\r
- 0..n input-Rows\r
\r
- 0..m output-Rows\r
\r
- optionale meta-Rows (Start/Ende, ok/Fehler, Dauer)\r
{\r
  "rows": [\r
    { "seq": 0,  "step": 0, "callId": "0", "g": "meta",   "k": "jobId",    "t": "string", "v": "c1a7..." },\r
    { "seq": 1,  "step": 0, "callId": "0", "g": "method", "k": "methodId", "t": "nodeid", "id": "ns=4;s=OPCUA.MyUaMethodA", "v": "ns=4;s=OPCUA.MyUaMethodA" },\r
    { "seq": 2,  "step": 0, "callId": "0", "g": "input",  "k": "speed",    "i": 0, "id": "ns=4;s=OPCUA.speed", "t": "int32", "v": 120, "uom": "rpm" },\r
    { "seq": 3,  "step": 0, "callId": "0", "g": "input",  "k": "dir",      "i": 1, "id": "ns=4;s=OPCUA.dir",   "t": "int32", "v": 1 },\r
    { "seq": 4,  "step": 0, "callId": "0", "g": "output", "k": "status",   "i": 0, "id": "ns=4;s=OPCUA.status","t": "bool",  "v": true },\r
    { "seq": 5,  "step": 0, "callId": "0", "g": "meta",   "k": "ok",                     "t": "bool",   "v": true },\r
    { "seq": 6,  "step": 0, "callId": "0", "g": "meta",   "k": "duration_ms",           "t": "uint32", "v": 37 },\r
\r
    { "seq": 7,  "step": 1, "callId": "0", "g": "method", "k": "methodId", "t": "nodeid", "id": "ns=4;s=OPCUA.MyUaMethodB", "v": "ns=4;s=OPCUA.MyUaMethodB" },\r
    { "seq": 8,  "step": 1, "callId": "0", "g": "input",  "k": "timeout",  "i": 0, "id": "ns=4;s=OPCUA.timeout","t": "uint32","v": 5000 },\r
    { "seq": 9,  "step": 1, "callId": "0", "g": "output", "k": "errorCode","i": 0, "id": "ns=4;s=OPCUA.err",    "t": "uint16","v": 0 },\r
    { "seq": 10, "step": 1, "callId": "0", "g": "meta",   "k": "ok",                     "t": "bool",   "v": true }\r
  ]\r
}""" ;
    rdfs:domain cl:SystemReaction ;
    rdfs:range xsd:string .

