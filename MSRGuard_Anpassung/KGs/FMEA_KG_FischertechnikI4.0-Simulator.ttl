    rdfs:subPropertyOf dp:hasExecutionParams .

dp:hasAPRating a owl:DatatypeProperty ;
    rdfs:domain cl:ActionPriority ;
    rdfs:range [ a rdfs:Datatype ;
            owl:oneOf [ a rdf:List ;
                    rdf:first "H" ;
                    rdf:rest [ a rdf:List ;
                            rdf:first "L" ;
                            rdf:rest [ a rdf:List ;
                                    rdf:first "M" ;
                                    rdf:rest () ] ] ] ] ;
    rdfs:subPropertyOf dp:hasRating .

dp:hasAPRating_inf a owl:DatatypeProperty ;
    rdfs:domain cl:ActionPriority ;
    rdfs:range [ a rdfs:Datatype ;
            owl:oneOf [ a rdf:List ;
                    rdf:first "H" ;
                    rdf:rest [ a rdf:List ;
                            rdf:first "L" ;
                            rdf:rest [ a rdf:List ;
                                    rdf:first "M" ;
