@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "FMEA-Team" as FMEA
actor "Prozessingenieur" as PE
actor "Wissensgraph" as KG
actor "Dokumentenbestand" as DOC

rectangle "Exception-Handling-Agent" {
  usecase "Fragen aus dem\nFMEA-Wissensbestand\nbeantworten" as UC4
  usecase "Natürlichsprachige\nFragen entgegennehmen" as UC4a
  usecase "Fragen auf den\nWissensbestand abbilden" as UC4b
  usecase "Ergebnisse fachlich\nverständlich aufbereiten" as UC4c
}

FMEA --> UC4
PE --> UC4
KG --> UC4b
DOC --> UC4b

UC4 .> UC4a : <<include>>
UC4 .> UC4b : <<include>>
UC4 .> UC4c : <<include>>
@enduml