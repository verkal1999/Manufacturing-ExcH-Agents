@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "FMEA-Team" as FMEA
actor "Prozessingenieur" as PE
actor "SPS / Steuerungssystem" as PLC
actor "Wissensgraph" as KG

rectangle "Exception-Handling-Agent" {
  usecase "Steuerungsänderungen\nnachverfolgen und mit\nFMEA koppeln" as UC5
  usecase "Änderungen an\nSteuerungsartefakten erkennen" as UC5a
  usecase "Änderungen einer FMEA-Funktion,\nMonitoring-Maßnahme oder\nSystemreaktion zuordnen" as UC5b
  usecase "Benachrichtigung erzeugen" as UC5c
  usecase "Vorschlag für\nSchnittstellenkonfiguration ableiten" as UC5d
}

FMEA --> UC5
PE --> UC5
PLC --> UC5a
UC5 --> KG

UC5 .> UC5a : <<include>>
UC5 .> UC5b : <<include>>
UC5 .> UC5c : <<include>>
UC5 .> UC5d : <<include>>
@enduml