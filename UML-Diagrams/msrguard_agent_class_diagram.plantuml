@startuml
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho
left to right direction

title msrguard - Agent Components Class Diagram

' Diese Notiz steht nun frei am Anfang
note "Focus: Python agent components under\nMSRGuard_Anpassung/python/msrguard.\n\nC++ runtime details and the full ingestion pipeline\nare intentionally abstracted." as MainNote

package "excH_agent_ui.py" {
  class ExcHAgentUI <<module>> {
    +streamlit_main(): None
    +start_analysis(event): None
    +run_pipeline(cfg, event): dict
  }

  class PipelineConfig <<dataclass>> {
    +enabled: bool
    +dir: str
    +runner: str
    +config: str
    +timeout_sec: int
  }

  class ChatbotConfig <<dataclass>> {
    +model: str
    +temperature: float
  }

  class UiConfig <<dataclass>> {
    +openai_api_key_file: str
  }

  UiConfig *-- PipelineConfig
  UiConfig *-- ChatbotConfig
  ExcHAgentUI ..> UiConfig : loads
}

package "excH_agent_core.py" {
  class ExcHAgentCore <<module>> {
    +handle_event(event): dict
  }

  class AgentResult <<dataclass>> {
    +status: str
    +finished_at_utc: str
    +diagnosis: str
    +next_steps: List<str>
    +proposed_actions: List<dict>
    +debug: dict
  }

  ExcHAgentCore ..> AgentResult : builds / returns
}

package "excH_chatbot.py" {
  class IncidentContext <<dataclass>> {
    +correlationId: str
    +processName: str
    +summary: str
    +triggerEvent: str
    +lastSkill: str
    +lastGEMMAStateBeforeFailure: str
    +kg_ttl_path: str
    +triggerD2: bool
    +from_input(obj): IncidentContext
    +from_event(event): IncidentContext
  }

  class ExcHChatBotSession {
    +bot: ChatBot
    +ctx: IncidentContext
    +bootstrap_evd2_plan: dict
    +ensure_bootstrap_plan(): dict
    +ask(user_msg, debug, include_bootstrap): dict
  }

  class ExcHChatbotFlows <<module>> {
    +build_session_from_input(obj): ExcHChatBotSession
    +build_evd2_diagnoseplan(session): dict
    +run_initial_analysis(session): dict
    +build_initial_prompt(ctx, diagnoseplan): str
  }

  ExcHChatBotSession *-- IncidentContext
  ExcHChatbotFlows ..> IncidentContext
  ExcHChatbotFlows ..> ExcHChatBotSession
}

package "chatbot_core.py" {
  
  package "KG + Similarity" {
    class SensorSnapshot <<dataclass>> {
      +program_name: str
      +sensor_values: Dict
    }

    class RoutineSignature <<dataclass>> {
      +pou_name: str
      +reachable_pous: List<str>
      +called_pou_names: List<str>
      +used_variable_names: List<str>
      +hardware_addresses: List<str>
      +port_names: List<str>
      +as_dict(): dict
    }

    class KGStore {
      +g: Graph
      +pou_uri_by_name(pou_name): URIRef
      +get_reachable_pous(root_pou_uri): Set<URIRef>
      +get_called_pous(pou_uri): Set<URIRef>
      +get_used_variables(pou_uri): Set<URIRef>
    }

    class SignatureExtractor {
      +kg: KGStore
      +extract_signature(pou_name): RoutineSignature
    }

    class RoutineIndex {
      +signatures: List<RoutineSignature>
      +save(path): None
      +load(path): RoutineIndex
      +build_from_kg(kg): RoutineIndex
      +find_similar(target, top_k): List<dict>
    }

    SignatureExtractor --> KGStore
    RoutineIndex o-- RoutineSignature
    RoutineIndex ..> SignatureExtractor : build_from_kg()
  }

  package "Planning + Registry" {
    abstract class BaseAgentTool {
      +name: str
      +description: str
      +usage_guide: str
      +get_prompt_signature(): str
      +get_documentation(): str
      +run(**kwargs): Any
    }

    class ToolRegistry {
      +register(tool): None
      +execute(tool_name, args): Any
      +get_system_prompt_part(): str
    }

    class ChatBot {
      +registry: ToolRegistry
      +llm: Callable
      +history: List<dict>
      +chat(user_msg, debug): dict
    }

    ToolRegistry o-- BaseAgentTool
    ChatBot --> ToolRegistry
  }

  package "Query Tools" {
    class ListProgramsTool
    class CalledPousTool
    class PouCallersTool
    class PouCodeTool
    class SearchVariablesTool
    class VariableTraceTool
    class GeneralSearchTool
    class StringTripleSearchTool {
      +graph: Graph
    }
    class Text2SparqlTool {
      +llm_invoke: Callable
      +schema_card: str
    }
    class SemanticSearchTool <<optional>>

    BaseAgentTool <|-- ListProgramsTool
    BaseAgentTool <|-- CalledPousTool
    BaseAgentTool <|-- PouCallersTool
    BaseAgentTool <|-- PouCodeTool
    BaseAgentTool <|-- SearchVariablesTool
    BaseAgentTool <|-- VariableTraceTool
    BaseAgentTool <|-- GeneralSearchTool
    BaseAgentTool <|-- StringTripleSearchTool
    BaseAgentTool <|-- Text2SparqlTool
    BaseAgentTool <|-- SemanticSearchTool
  }

  package "Analysis Tools" {
    class ExceptionAnalysisTool {
      +kg: KGStore
      +index: RoutineIndex
    }
    class GraphInvestigateTool

    BaseAgentTool <|-- ExceptionAnalysisTool
    BaseAgentTool <|-- GraphInvestigateTool
  }

  package "evD2 Tools" {
    class EvD2DiagnosisTool
    class EvD2UnifiedTraceTool
    class EvD2RequirementPathsTool
    class EvD2PathTracingTool

    BaseAgentTool <|-- EvD2DiagnosisTool
    BaseAgentTool <|-- EvD2UnifiedTraceTool
    BaseAgentTool <|-- EvD2RequirementPathsTool
    BaseAgentTool <|-- EvD2PathTracingTool
  }

  ExceptionAnalysisTool --> KGStore
  ExceptionAnalysisTool --> RoutineIndex
  ExceptionAnalysisTool ..> RoutineSignature
  ExceptionAnalysisTool ..> SensorSnapshot
  StringTripleSearchTool --> KGStore
}

package "d2_trace_analysis.py" {
  class D2TraceAnalysis <<module>> {
    +run_unified_set_and_condition_trace(): dict
    +build_requirement_tables(): dict
  }

  class Tracer <<dataclass>> {
    +enabled: bool
    +lines: List<str>
    +log(msg): None
  }

  class FbdNode <<dataclass>> {
    +var: str
    +func: str
    +args: List<FbdNode>
  }

  D2TraceAnalysis *-- Tracer
  D2TraceAnalysis *-- FbdNode
}


' Cross-Package Relationships
ExcHAgentUI ..> ExcHAgentCore : handle_event()
ExcHAgentUI ..> IncidentContext : from_event()
ExcHAgentUI ..> ChatBot : build_bot()
ExcHAgentUI ..> ExcHChatBotSession : creates
ExcHAgentUI ..> ExcHChatbotFlows : run_initial_analysis()

IncidentContext ..> AgentResult : optional input
ExcHChatBotSession --> ChatBot : delegates
ExcHChatbotFlows ..> ChatBot : build_bot()

EvD2UnifiedTraceTool ..> D2TraceAnalysis
EvD2RequirementPathsTool ..> D2TraceAnalysis
EvD2PathTracingTool ..> D2TraceAnalysis

note right of ExcHChatBotSession
Caches a deterministic evD2 bootstrap plan
before the open chat loop continues.
end note

note bottom of ChatBot
build_bot() loads the KG TTL, creates KGStore 
and RoutineIndex, registers tools.
end note

@enduml