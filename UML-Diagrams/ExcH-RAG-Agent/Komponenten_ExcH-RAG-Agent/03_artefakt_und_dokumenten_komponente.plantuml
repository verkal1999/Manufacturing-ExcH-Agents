@startuml

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
top to bottom direction

package "Artefakt- und Dokumenten-Komponente" {
  class ArtifactCatalog <<dataclass>> {
    +xml_path: str
    +document_type: str
  }

  class PLCOpenXmlSource {
    +load_text(xml_path: str): str
  }

  class XmlChunker {
    +chunk_text(text: str, xml_path: str): List<RagChunk>
  }

  class RagChunk <<dataclass>> {
    +chunk_id: str
    +kind: str
    +name: str
    +text: str
    +metadata: dict
    +preview(): str
  }

  class DocumentCorpus {
    +chunks: List<RagChunk>
    +add(chunk: RagChunk): None
  }

  ArtifactCatalog --> PLCOpenXmlSource : verweist auf
  PLCOpenXmlSource ..> XmlChunker : liefert XML an
  XmlChunker ..> RagChunk : erzeugt
  XmlChunker --> DocumentCorpus : füllt
  DocumentCorpus o-- RagChunk
}

@enduml
