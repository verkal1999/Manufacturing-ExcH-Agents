@startuml
title ExcH-RAG-Agent - Generierungs- und Leitplanken-Komponente

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
left to right direction

package "Generierungs- und Leitplanken-Komponente" {
  class GenerationRequest <<value object>> {
    +question: str
    +extra_context: str
  }

  class RetrievedContextBlock <<value object>> {
    +rank: int
    +kind: str
    +name: str
    +score: float
    +text: str
  }

  class GroundedContextBundle <<value object>> {
    +event_context: str
    +retrieved_chunks: List<RetrievedContextBlock>
  }

  class GuardrailPolicy {
    +enforce(req: GenerationRequest): GenerationRequest
    +validate(result: GenerationResult): None
  }

  class AnswerContract {
    +required_sections: List<str>
  }

  class GroundedAnswerGenerator {
    +generate(req: GenerationRequest, ctx: GroundedContextBundle): GenerationResult
  }

  class GenerationResult <<value object>> {
    +answer: str
    +uncertainty_notes: List<str>
  }

  GroundedContextBundle *-- RetrievedContextBlock
  GroundedAnswerGenerator --> GuardrailPolicy : beachtet
  GroundedAnswerGenerator --> AnswerContract : formatiert nach
  GroundedAnswerGenerator ..> GenerationRequest : verarbeitet
  GroundedAnswerGenerator ..> GroundedContextBundle : nutzt
  GroundedAnswerGenerator --> GenerationResult : erzeugt
}

note right of GuardrailPolicy
Kap. 3.4.2 fordert:
- nur auf Basis des Kontexts antworten
- Beobachtung, Struktur und Schluss trennen
- Unsicherheit offen benennen
- keine unbelegten Ursachen erfinden
end note

@enduml
