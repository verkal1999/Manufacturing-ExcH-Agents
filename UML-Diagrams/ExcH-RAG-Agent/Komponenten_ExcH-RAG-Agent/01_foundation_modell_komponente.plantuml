@startuml

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
top to bottom direction

package "Foundation-Modell-Komponente" {
  class RagConfig <<dataclass>> {
    +model: str
    +temperature: float
  }

  class ModelSelectionPolicy {
    +select_profile(task_kind: str): ModelProfile
  }

  class ModelProfile <<dataclass>> {
    +name: str
    +cost_class: str
    +context_window: int
  }

  class PromptRequest <<dataclass>> {
    +system_prompt: str
    +user_prompt: str
  }

  class FoundationModelGateway {
    +invoke(req: PromptRequest): ModelResponse
  }

  class ModelResponse <<dataclass>> {
    +answer: str
    +finish_reason: str
  }

  RagConfig --> ModelSelectionPolicy : parametrisiert
  ModelSelectionPolicy --> ModelProfile : wählt
  FoundationModelGateway --> ModelProfile : nutzt
  FoundationModelGateway ..> PromptRequest : verarbeitet
  FoundationModelGateway --> ModelResponse : erzeugt
}

@enduml
