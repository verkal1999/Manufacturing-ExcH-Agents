@startuml

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
top to bottom direction

package "Interaktions- und Ausgabe-Komponente" {
  class ExcHAgentUI <<module>> {
    +streamlit_main(): None
    +start_analysis(event): None
    +run_pipeline(cfg, event): dict
  }

  class ResponseEnvelope <<dataclass>> {
    +diagnosis: str
    +next_steps: List<str>
    +proposed_actions: List<dict>
  }

  class StructuredToolResult <<dataclass>> {
    +tool_name: str
    +payload: dict
  }

  class FollowUpQuestion <<dataclass>> {
    +text: str
    +priority: int
  }

  class OutputGuardrail {
    +check(response: ResponseEnvelope): EscalationDecision
  }

  class EscalationDecision <<dataclass>> {
    +requires_human_review: bool
    +reason: str
  }

  class AuditTrailEntry <<dataclass>> {
    +timestamp_utc: str
    +kind: str
    +data: dict
  }

  class SessionResumeRequest <<dataclass>> {
    +user_msg: str
    +reuse_session: bool
  }

  ExcHAgentUI ..> ResponseEnvelope : stellt bereit
  ResponseEnvelope o-- StructuredToolResult
  ResponseEnvelope o-- FollowUpQuestion
  OutputGuardrail ..> ResponseEnvelope : prüft
  OutputGuardrail --> EscalationDecision : erzeugt
  ExcHAgentUI o-- AuditTrailEntry
  ExcHAgentUI ..> SessionResumeRequest : verarbeitet
}
@enduml
