@startuml

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
top to bottom direction

package "Modell-, Planner- und Werkzeug-Komponente" {
  class Planner {
    +plan(ctx): AnalysisPlan
    +replan(ctx, partial_results): AnalysisPlan
  }

  class AnalysisPlan <<dataclass>> {
    +goal: str
    +steps: List<PlanStep>
  }

  class PlanStep <<dataclass>> {
    +tool_name: str
    +purpose: str
  }

  class ToolRegistry {
    +register(tool): None
    +execute(tool_name: str, args: dict): Any
  }

  abstract class BaseAgentTool {
    +name: str
    +description: str
    +run(**kwargs): Any
  }

  class KGQueryTool
  class StructureCodeAnalysisTool
  class VariableSignalAnalysisTool
  class PathReconstructionTool

  class ToolResultBundle <<dataclass>> {
    +results: Dict<str, Any>
  }

  class FoundationModelAdapter {
    +synthesize(ctx, plan, results): str
  }

  AnalysisPlan *-- PlanStep
  Planner --> AnalysisPlan : erzeugt
  Planner --> ToolRegistry : orchestriert
  ToolRegistry o-- BaseAgentTool
  BaseAgentTool <|-- KGQueryTool
  BaseAgentTool <|-- StructureCodeAnalysisTool
  BaseAgentTool <|-- VariableSignalAnalysisTool
  BaseAgentTool <|-- PathReconstructionTool
  Planner --> ToolResultBundle : sammelt
  FoundationModelAdapter ..> ToolResultBundle : nutzt
  Planner --> FoundationModelAdapter : übergibt Ergebnisse an
}

@enduml
